<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- カメラプレビュー（フルスクリーン） -->
    <TextureView
        android:id="@+id/texture_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ========== 上部エリア ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        android:background="#44000000">

        <!-- タイマーボタン（左） -->
        <TextView
            android:id="@+id/btn_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱ OFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="#55000000"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />

        <!-- アプリ名（中央） -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="VISUAL FIT"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium" />

        <!-- 右側スペーサー（タイマーと対称に） -->
        <View
            android:layout_width="72dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- ========== カウントダウン表示（中央オーバーレイ） ========== -->
    <TextView
        android:id="@+id/txt_countdown"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:gravity="center"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#88000000"
        android:visibility="gone" />

    <!-- ========== 下部エリア（iPhoneスタイル） ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#66000000"
        android:paddingTop="20dp"
        android:paddingBottom="48dp">

        <!-- ガイドテキスト -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="全身が映るように立ってください"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- コントロールバー: [左スペース] [シャッター] [フリップ] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="32dp">

            <!-- 左: タイマー状態インジケーター -->
            <TextView
                android:id="@+id/txt_timer_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text=""
                android:textColor="#FFCC00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="invisible" />

            <!-- 中央: シャッターボタン（iPhoneの白いリング） -->
            <FrameLayout
                android:id="@+id/btn_capture"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/shutter_button" />

            <!-- 右: カメラフリップボタン -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btn_flip"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_flip_camera"
                    android:background="#55FFFFFF"
                    android:padding="10dp"
                    android:scaleType="fitCenter" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
