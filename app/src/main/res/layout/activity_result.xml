<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 試着画像（フルブリード） -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="480dp">

            <ImageView
                android:id="@+id/img_tryon_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/primary_container"
                android:contentDescription="試着結果" />

            <!-- 左上: ブランドロゴ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:text="VIRTUALFIT"
                android:textSize="10sp"
                android:letterSpacing="0.25"
                android:textColor="#CCFFFFFF"
                android:fontFamily="sans-serif-medium"
                android:background="#33000000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

            <!-- 右下: 商品価格バッジ -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:background="#F0FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_product_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="楽天市場"
                    android:textSize="9sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.05" />
            </LinearLayout>

        </FrameLayout>

        <!-- コンテンツエリア -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- 商品名 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECTED ITEM"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textColor="@color/accent"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/txt_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="15sp"
                android:textColor="@color/on_surface"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 区切り線 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- スタイリストコメント -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STYLIST'S NOTE"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/txt_styling_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:lineSpacingMultiplier="1.7"
                android:fontFamily="sans-serif-light" />

            <!-- 購入ボタン -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_purchase"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:text="SHOP NOW"
                android:textSize="13sp"
                android:letterSpacing="0.15"
                style="@style/Button.Primary" />

            <!-- やり直しボタン -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="TRY ANOTHER LOOK"
                android:textSize="13sp"
                android:letterSpacing="0.15"
                style="@style/Button.Outline" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
